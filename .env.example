# ============================================================
# Firecrawl Simple - Environment Configuration
# ============================================================
# Copy this file to .env and fill in the required values.

# ============================================================
# Image Tags (pin for reproducibility, use latest to always get newest)
# ============================================================

FIRECRAWL_IMAGE_TAG=latest
PLAYWRIGHT_IMAGE_TAG=latest
NUQ_POSTGRES_IMAGE_TAG=latest

# ============================================================
# Firecrawl Core Services
# ============================================================

# Host port mapping (host:container)
PORT=3002

# Internal port inside the container
INTERNAL_PORT=3002

# Host binding (0.0.0.0 for remote access)
HOST=0.0.0.0

# Disable database authentication (set to true if using Supabase)
USE_DB_AUTHENTICATION=false

# Bull Queue Manager auth key (CHANGE THIS in production)
BULL_AUTH_KEY=CHANGEME

# PostgreSQL credentials
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres

# Worker configuration
NUM_WORKERS_PER_QUEUE=8
CRAWL_CONCURRENT_REQUESTS=10
MAX_CONCURRENT_JOBS=5
BROWSER_POOL_SIZE=5
EXTRACT_WORKER_PORT=3004
WORKER_PORT=3005

# Resource limits (adjust for your machine; defaults assume 8+ cores / 16GB+ RAM)
FIRECRAWL_CPUS=4.0
FIRECRAWL_MEM_LIMIT=8G
PLAYWRIGHT_CPUS=2.0
PLAYWRIGHT_MEM_LIMIT=4G

# ============================================================
# Firecrawl MCP Server
# ============================================================

# URL of the internal Firecrawl API
FIRECRAWL_API_URL=http://firecrawl:3002

# Firecrawl API key (leave empty for self-hosted without auth)
FIRECRAWL_API_KEY=

# ============================================================
# Serper MCP Server
# ============================================================

# Get your API key at https://serper.dev (required)
SERPER_API_KEY=

# ============================================================
# Optional: AI/LLM Integration (for Firecrawl extract features)
# ============================================================
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
# MODEL_NAME=
# MODEL_EMBEDDING_NAME=
# OLLAMA_BASE_URL=

# ============================================================
# Optional: Proxy Configuration
# ============================================================
# PROXY_SERVER=
# PROXY_USERNAME=
# PROXY_PASSWORD=
